from __future__ import annotations

from pathlib import Path

import pandas as pd
from sklearn.calibration import CalibratedClassifierCV
from sklearn.frozen import FrozenEstimator
from sklearn.metrics import accuracy_score, brier_score_loss, log_loss, roc_auc_score
from xgboost import XGBClassifier

try:
    # Optional plotting dependency. The script still runs if matplotlib is missing.
    import matplotlib.pyplot as plt
except ImportError:  # pragma: no cover - optional dependency for plotting
    plt = None


# Columns kept in the CSV for debugging / traceability but dropped before model training.
DEBUG_DROP_COLUMNS = [
    "fighter_a_won",
    "fight_id",
    "event_id",
    "event_date",
    "event_name",
    "fighter_a_id",
    "fighter_a_name",
    "fighter_b_id",
    "fighter_b_name",
]
# A "low experience" fight is defined as the smaller of the two fighters' prior UFC fight counts.
LOW_EXPERIENCE_THRESHOLD = 3
# Reserve the newest portion of the training split for early stopping and Platt calibration.
CALIBRATION_FRACTION = 0.2
# Where diagnostic plot files are saved if plotting is available.
ARTIFACT_DIR = Path("artifacts") / "xgboost"


def load_data() -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    # Load the prebuilt chronological splits. The model does not create its own split.
    train_df = pd.read_csv("data/current_model/features/train.csv")
    validation_df = pd.read_csv("data/current_model/features/validation.csv")
    test_df = pd.read_csv("data/current_model/features/test.csv")
    return train_df, validation_df, test_df


def split_features_and_target(df: pd.DataFrame) -> tuple[pd.DataFrame, pd.Series]:
    # y is the supervised target: 1 if fighter A won, 0 otherwise.
    y = df["fighter_a_won"]
    # X is every actual model feature after removing debug columns.
    x = df.drop(columns=DEBUG_DROP_COLUMNS)
    return x, y


def add_experience_columns(results_df: pd.DataFrame) -> pd.DataFrame:
    # Pull pre-fight experience from fighter_snapshots so we can inspect low-experience bouts.
    snapshots = pd.read_csv("data/current_model/features/fighter_snapshots.csv")
    snapshots = snapshots[["fight_id", "fighter_id", "ufc_fights"]].drop_duplicates()

    fighter_a_experience = snapshots.rename(
        columns={"fighter_id": "fighter_a_id", "ufc_fights": "fighter_a_prior_fights"}
    )
    fighter_b_experience = snapshots.rename(
        columns={"fighter_id": "fighter_b_id", "ufc_fights": "fighter_b_prior_fights"}
    )

    enriched = results_df.merge(fighter_a_experience, on=["fight_id", "fighter_a_id"], how="left")
    enriched = enriched.merge(fighter_b_experience, on=["fight_id", "fighter_b_id"], how="left")
    enriched["fighter_a_prior_fights"] = pd.to_numeric(enriched["fighter_a_prior_fights"], errors="coerce")
    enriched["fighter_b_prior_fights"] = pd.to_numeric(enriched["fighter_b_prior_fights"], errors="coerce")
    enriched["min_prior_fights"] = enriched[["fighter_a_prior_fights", "fighter_b_prior_fights"]].min(axis=1)
    return enriched


def add_weight_class_labels(results_df: pd.DataFrame, feature_df: pd.DataFrame) -> pd.DataFrame:
    # Recover a readable weight-class label from the one-hot encoded feature columns.
    weight_columns = [column for column in feature_df.columns if column.startswith("weight_class_")]
    if not weight_columns:
        results_df["weight_class_label"] = "unknown"
        return results_df

    weight_labels = (
        feature_df[weight_columns]
        .idxmax(axis=1)
        .str.replace("weight_class_", "", regex=False)
    )
    results_df["weight_class_label"] = weight_labels
    return results_df


def canonicalize_results(results_df: pd.DataFrame) -> pd.DataFrame:
    # Keep one canonical row per real fight using the original schema orientation.
    schema = pd.read_csv("data/current_model/features/ml_training_schema.csv")
    canonical_keys = schema[["fight_id", "fighter_a_id", "fighter_b_id", "fighter_a_won"]].drop_duplicates()
    canonical = results_df.merge(
        canonical_keys.assign(_is_canonical=1),
        on=["fight_id", "fighter_a_id", "fighter_b_id", "fighter_a_won"],
        how="left",
    )
    canonical = canonical[canonical["_is_canonical"] == 1].drop(columns="_is_canonical")
    return canonical.reset_index(drop=True)


def safe_auc(y_true: pd.Series, probabilities: pd.Series) -> float | None:
    if y_true.nunique() < 2:
        return None
    return float(roc_auc_score(y_true, probabilities))


def compute_metric_values(
    y_true: pd.Series, probabilities: pd.Series, predictions: pd.Series
) -> dict[str, float | None]:
    return {
        "log_loss": float(log_loss(y_true, probabilities)),
        "brier_score": float(brier_score_loss(y_true, probabilities)),
        "auc": safe_auc(y_true, probabilities),
        "accuracy": float(accuracy_score(y_true, predictions)),
    }


def print_metric_block(label: str, y_true: pd.Series, probabilities: pd.Series, predictions: pd.Series) -> None:
    # Log loss and Brier score use probabilities, AUC measures ranking quality, and accuracy uses hard picks.
    metrics = compute_metric_values(y_true, probabilities, predictions)
    print(f"{label} Log Loss:", metrics["log_loss"])
    print(f"{label} Brier Score:", metrics["brier_score"])
    print(f"{label} AUC:", metrics["auc"])
    print(f"{label} Accuracy:", metrics["accuracy"])


def summarize_feature_importance(model: XGBClassifier, feature_names: list[str]) -> pd.Series:
    # XGBoost exposes a relative importance score for each input feature.
    importance = pd.Series(model.feature_importances_, index=feature_names).sort_values(ascending=False)
    print("\nTop 20 Feature Importances")
    print(importance.head(20).to_string())
    return importance


def plot_feature_importance(importance: pd.Series) -> None:
    if plt is None:
        print("\nmatplotlib is not installed, skipping feature importance plot.")
        return

    # Save a top-20 horizontal bar chart so we can inspect what the model is leaning on most.
    ARTIFACT_DIR.mkdir(parents=True, exist_ok=True)
    top_importance = importance.head(20).sort_values()
    figure = plt.figure(figsize=(10, 7))
    top_importance.plot(kind="barh")
    plt.title("Top 20 XGBoost Feature Importances")
    plt.xlabel("Importance")
    plt.tight_layout()
    output_path = ARTIFACT_DIR / "top_feature_importance.png"
    plt.savefig(output_path, dpi=150)
    plt.close(figure)
    print(f"\nSaved feature importance plot to {output_path}")


def inspect_prediction_behavior(results_df: pd.DataFrame) -> None:
    # "Confident wrong" examples are useful for spotting missing features or model blind spots.
    confident_wrong = results_df[results_df["pred_fighter_a_win"] != results_df["fighter_a_won"]].copy()
    confident_wrong["confidence"] = confident_wrong["prob_fighter_a_win"].where(
        confident_wrong["pred_fighter_a_win"] == 1,
        1 - confident_wrong["prob_fighter_a_win"],
    )

    closest_to_coin_flip = results_df.copy()
    # Near-0.5 probabilities are the fights the model is least certain about.
    closest_to_coin_flip["distance_from_50"] = (closest_to_coin_flip["prob_fighter_a_win"] - 0.5).abs()

    print("\nMost Confident Wrong Predictions")
    print(
        confident_wrong.sort_values("confidence", ascending=False)[
            [
                "event_date",
                "event_name",
                "fighter_a_name",
                "fighter_b_name",
                "fighter_a_won",
                "pred_fighter_a_win",
                "prob_fighter_a_win",
                "confidence",
            ]
        ]
        .head(15)
        .to_string(index=False)
    )

    print("\nMost Uncertain Predictions")
    print(
        closest_to_coin_flip.sort_values("distance_from_50")[
            [
                "event_date",
                "event_name",
                "fighter_a_name",
                "fighter_b_name",
                "fighter_a_won",
                "pred_fighter_a_win",
                "prob_fighter_a_win",
                "distance_from_50",
            ]
        ]
        .head(15)
        .to_string(index=False)
    )


def subgroup_frames(results_df: pd.DataFrame) -> dict[str, pd.DataFrame]:
    groups: dict[str, pd.DataFrame] = {
        "overall": results_df,
        "female_fights": results_df[results_df["is_women_fight"] == 1],
        "title_fights": results_df[results_df["is_title_fight"] == 1],
        "low_experience": results_df[results_df["min_prior_fights"] <= LOW_EXPERIENCE_THRESHOLD],
    }
    for weight_class, subset in results_df.groupby("weight_class_label"):
        if len(subset) < 20:
            continue
        groups[f"weight_class:{weight_class}"] = subset
    return groups


def metric_row(model_label: str, subgroup: str, subset: pd.DataFrame) -> dict[str, object]:
    subset_predictions = subset["pred_fighter_a_win"]
    subset_probabilities = subset["prob_fighter_a_win"]
    subset_target = subset["fighter_a_won"]
    metrics = compute_metric_values(subset_target, subset_probabilities, subset_predictions)
    return {
        "model": model_label,
        "subgroup": subgroup,
        "rows": len(subset),
        "log_loss": metrics["log_loss"],
        "brier_score": metrics["brier_score"],
        "auc": metrics["auc"],
        "accuracy": metrics["accuracy"],
    }


def summarize_results(model_label: str, results_df: pd.DataFrame) -> pd.DataFrame:
    rows = [
        metric_row(model_label, subgroup, subset)
        for subgroup, subset in subgroup_frames(results_df).items()
        if not subset.empty
    ]
    return pd.DataFrame(rows)


def subgroup_metrics(results_df: pd.DataFrame, label: str, mask: pd.Series) -> None:
    # Re-run the same validation metrics on a subset to find where the model is stronger/weaker.
    subset = results_df[mask].copy()
    if subset.empty:
        print(f"\n{label}: no rows")
        return

    subset_predictions = subset["pred_fighter_a_win"]
    subset_probabilities = subset["prob_fighter_a_win"]
    subset_target = subset["fighter_a_won"]
    metrics = compute_metric_values(subset_target, subset_probabilities, subset_predictions)

    print(f"\n{label} ({len(subset)} rows)")
    print("Log Loss:", metrics["log_loss"])
    print("Brier Score:", metrics["brier_score"])
    print("AUC:", metrics["auc"])
    print("Accuracy:", metrics["accuracy"])


def weight_class_metrics(results_df: pd.DataFrame) -> None:
    # Weight-class slice to see whether model quality changes across divisions.
    print("\nValidation Metrics By Weight Class")
    for weight_class, subset in results_df.groupby("weight_class_label"):
        if len(subset) < 20:
            continue
        metrics = compute_metric_values(
            subset["fighter_a_won"],
            subset["prob_fighter_a_win"],
            subset["pred_fighter_a_win"],
        )
        print(f"\n{weight_class} ({len(subset)} rows)")
        print("Log Loss:", metrics["log_loss"])
        print("Brier Score:", metrics["brier_score"])
        print("AUC:", metrics["auc"])
        print("Accuracy:", metrics["accuracy"])


def split_train_and_calibration(df: pd.DataFrame) -> tuple[pd.DataFrame, pd.DataFrame]:
    calibration_rows = max(1, int(len(df) * CALIBRATION_FRACTION))
    if calibration_rows >= len(df):
        calibration_rows = len(df) - 1
    train_rows = len(df) - calibration_rows
    return df.iloc[:train_rows].copy(), df.iloc[train_rows:].copy()


def build_model() -> XGBClassifier:
    return XGBClassifier(
        n_estimators=300,
        max_depth=6,
        learning_rate=0.05,
        subsample=0.7,
        colsample_bytree=0.8,
        min_child_weight=7,
        gamma=0,
        reg_alpha=0,
        reg_lambda=1,
        eval_metric="logloss",
        early_stopping_rounds=10,
        random_state=42,
    )


def build_validation_results(
    validation_df: pd.DataFrame,
    feature_df: pd.DataFrame,
    probabilities,
    predictions,
) -> pd.DataFrame:
    validation_results = validation_df.copy()
    validation_results["prob_fighter_a_win"] = probabilities
    validation_results["pred_fighter_a_win"] = predictions
    validation_results["correct"] = (
        validation_results["pred_fighter_a_win"] == validation_results["fighter_a_won"]
    ).astype(int)
    validation_results = add_weight_class_labels(validation_results, feature_df)
    validation_results = add_experience_columns(validation_results)
    return canonicalize_results(validation_results)


def print_all_diagnostics(model_label: str, y_true: pd.Series, results_df: pd.DataFrame) -> None:
    print_metric_block(
        f"{model_label} Validation",
        y_true,
        results_df["prob_fighter_a_win"],
        results_df["pred_fighter_a_win"],
    )
    print_metric_block(
        f"{model_label} Fight-Level Validation",
        results_df["fighter_a_won"],
        results_df["prob_fighter_a_win"],
        results_df["pred_fighter_a_win"],
    )
    subgroup_metrics(
        results_df,
        f"{model_label} Female Fights",
        results_df["is_women_fight"] == 1,
    )
    subgroup_metrics(
        results_df,
        f"{model_label} Title Fights",
        results_df["is_title_fight"] == 1,
    )
    subgroup_metrics(
        results_df,
        f"{model_label} Low Experience Fights (min prior fights <= {LOW_EXPERIENCE_THRESHOLD})",
        results_df["min_prior_fights"] <= LOW_EXPERIENCE_THRESHOLD,
    )
    print(f"\n{model_label} Validation Metrics By Weight Class")
    for weight_class, subset in results_df.groupby("weight_class_label"):
        if len(subset) < 20:
            continue
        metrics = compute_metric_values(
            subset["fighter_a_won"],
            subset["prob_fighter_a_win"],
            subset["pred_fighter_a_win"],
        )
        print(f"\n{weight_class} ({len(subset)} rows)")
        print("Log Loss:", metrics["log_loss"])
        print("Brier Score:", metrics["brier_score"])
        print("AUC:", metrics["auc"])
        print("Accuracy:", metrics["accuracy"])


def print_comparison_summary(raw_summary: pd.DataFrame, calibrated_summary: pd.DataFrame) -> None:
    combined = pd.concat([raw_summary, calibrated_summary], ignore_index=True)
    pivot = combined.pivot(index="subgroup", columns="model", values=["log_loss", "brier_score", "auc", "accuracy"])
    pivot.columns = [f"{metric}_{model}" for metric, model in pivot.columns]
    pivot = pivot.reset_index()
    pivot["log_loss_delta"] = pivot["log_loss_platt_calibrated"] - pivot["log_loss_uncalibrated"]
    pivot["brier_score_delta"] = pivot["brier_score_platt_calibrated"] - pivot["brier_score_uncalibrated"]
    pivot["auc_delta"] = pivot["auc_platt_calibrated"] - pivot["auc_uncalibrated"]
    pivot["accuracy_delta"] = pivot["accuracy_platt_calibrated"] - pivot["accuracy_uncalibrated"]

    print("\nCalibration Comparison Summary")
    print(
        pivot[
            [
                "subgroup",
                "log_loss_uncalibrated",
                "log_loss_platt_calibrated",
                "log_loss_delta",
                "brier_score_uncalibrated",
                "brier_score_platt_calibrated",
                "brier_score_delta",
                "auc_uncalibrated",
                "auc_platt_calibrated",
                "auc_delta",
                "accuracy_uncalibrated",
                "accuracy_platt_calibrated",
                "accuracy_delta",
            ]
        ]
        .sort_values("subgroup")
        .to_string(index=False)
    )


def main() -> None:
    # Use train for fitting and validation for model selection / diagnostics.
    train_df, validation_df, _ = load_data()

    calibration_train_df, calibration_df = split_train_and_calibration(train_df)
    x_train, y_train = split_features_and_target(calibration_train_df)
    x_calibration, y_calibration = split_features_and_target(calibration_df)
    x_val, y_val = split_features_and_target(validation_df)

    print(
        "Using the most recent "
        f"{len(calibration_df)} rows from the training split for early stopping and Platt calibration."
    )

    # Early stopping watches the held-out calibration slice and stops if it stalls for 10 rounds.
    base_model = build_model()
    base_model.fit(x_train, y_train, eval_set=[(x_calibration, y_calibration)], verbose=False)

    # Compare raw probabilities against a sigmoid-calibrated version of the same fitted model.
    raw_probability = base_model.predict_proba(x_val)[:, 1]
    raw_predictions = (raw_probability >= 0.5).astype(int)

    calibrator = CalibratedClassifierCV(estimator=FrozenEstimator(base_model), method="sigmoid")
    calibrator.fit(x_calibration, y_calibration)
    calibrated_probability = calibrator.predict_proba(x_val)[:, 1]
    calibrated_predictions = (calibrated_probability >= 0.5).astype(int)

    # General feature-importance diagnostics.
    importance = summarize_feature_importance(base_model, x_train.columns.tolist())
    plot_feature_importance(importance)

    raw_results = build_validation_results(validation_df, x_val, raw_probability, raw_predictions)
    calibrated_results = build_validation_results(
        validation_df,
        x_val,
        calibrated_probability,
        calibrated_predictions,
    )

    print_all_diagnostics("Uncalibrated", y_val, raw_results)
    print_all_diagnostics("Platt-Calibrated", y_val, calibrated_results)

    print("\nUncalibrated Error Inspection")
    inspect_prediction_behavior(raw_results)

    raw_summary = summarize_results("uncalibrated", raw_results)
    calibrated_summary = summarize_results("platt_calibrated", calibrated_results)
    print_comparison_summary(raw_summary, calibrated_summary)


if __name__ == "__main__":
    main()
